# Supabase Configuration (Client-side - safe to expose)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI API Keys (Client-side - rate limited recommended)
VITE_GEMINI_API_KEY=your_gemini_api_key

# Server-side only (NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_only_for_server
GEMINI_API_KEY=your_gemini_key_server_only
FOURSQUARE_API_KEY=your_foursquare_key
